<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thank You!</title>
    <link rel="stylesheet" href="styles/guestbook-styles.css">
</head>
<body>
    <section class="navigation">
        <a href="/">Home</a>
        <a href="/contact">Contact Me</a>
        <a href="/admin">Admin</a>
        <a href="https://www.linkedin.com/in/kevinjmiclea/">LinkedIn</a>
        <a href="https://github.com/plageous">Github</a>
    </section>
    <h1>Thanks <%= contact.fname %>!</h1>
    <h1>Your information has been logged, and I will reply to you soon!</h1>
    <h2>Your details:</h2>
    <p><strong><%= contact.fname %> <%= contact.lname %></strong></p>
    <% if (contact.job.trim() != "") { %>
        <p>You are a(n) <%= contact.job %>.</p>
    <% } %>
    <% if (contact.company.trim() != "") { %>
        <p>You work at <%= contact.company %>.</p>
    <% } %>
    <% if (contact.linkedin.trim() != "") { %>
        <p>Your LinkedIn URL: <%= contact.linkedin %></p>
    <% } %>
    <% if (contact.email.trim() != "") { %>
        <p>Your email: <%= contact.email %></p>
    <% } %>
    <% if (contact.mailing == "on") { %>
        <p>You are signed up for my mailing list.</p>
        <p>You will recieve emails in <%= contact.method %> format.</p>
    <% } %>
    <% if (contact.message.trim() != "") { %>
        <p>Your message to me: <%= contact.message %></p>
    <% } %>
    <a href="/">Submit another contact.</a>
</body>
</html>